   ],
   "source": [
    "# 1. Define the Baseline vectors\n",
    "baseline_mapping = {\n",
    "    \"Image Scoring\": \"00001111\", \n",
    "    \"Stern Judging\": \"11000011\", \n",
    "    \"Shunning\": \"00000011\",\n",
    "    \"Simple Standing\": \"11001111\"\n",
    "}\n",
    "\n",
    "# 2. Extract full stats for Baselines from your original data\n",
    "# We calculate the stats the same way as your top_10 function to ensure consistency\n",
    "for base_name, ebsn_str in baseline_mapping.items():\n",
    "    # Filter original data for this specific baseline vector\n",
    "    b_data = merged_df[(merged_df['8bit_vector'] == ebsn_str)]\n",
    "    b_data = b_data[b_data.q==0.75]\n",
    "    b_data = b_data[b_data.base_social_norm==base_name]\n",
    "    b_data = b_data[b_data.eps==0.01]\n",
    "    b_data = b_data[b_data.gens==2000]\n",
    "    b_data = b_data[b_data.consensus_thresh==0]\n",
    "    if not b_data.empty:\n",
    "        acr = b_data['average_cooperation'].mean()\n",
    "        if acr > 1.1: acr /= 100.0\n",
    "        \n",
    "        # Build a row compatible with top_10_final\n",
    "        row = {\n",
    "            'Base Norm': base_name,\n",
    "            'EBSN': ebsn_str,\n",
    "            'ACR': acr,\n",
    "            'Standard Deviation': b_data['average_cooperation'].std() / (100.0 if b_data['average_cooperation'].mean() > 1.1 else 1.0),\n",
    "            'Cooperative-Social Norm': base_name, # It is its own rule\n",
    "            'is_baseline': 1 # Sorting flag\n",
    "        }\n",
    "        baseline_rows.append(row)\n",
    "\n",
    "df_baselines_rows = pd.DataFrame(baseline_rows)\n",
    "\n",
    "# 3. Combine with Top 10 and Sort\n",
    "# We add a temporary 'is_baseline' flag to your top_10_final\n",
    "df_facet = all_results_q75[all_results_q75[\"Base Norm\"].isin(leading_four)].copy()\n",
    "df_facet['is_baseline'] = 0\n",
    "\n",
    "# Combine\n",
    "df_combined = pd.concat([df_facet, df_baselines_rows], ignore_index=True)\n",
    "\n",
    "# SORTING LOGIC: \n",
    "# Primary: Base Norm\n",
    "# Secondary: is_baseline (0s first, 1s last)\n",
    "# Tertiary: ACR (Descending)\n",
    "df_combined = df_combined.sort_values(\n",
    "    ['Base Norm', 'is_baseline', 'ACR'], \n",
    "    ascending=[True, True, False]\n",
    ")\n",
    "\n",
    "# 4. Charting logic\n",
    "full_domain = [\"Stern Judging\", \"Simple Standing\", \"Shunning\", \"Image Scoring\", \"All Good\", \"All Bad\", \"paradoxical Simple Standing\", \"paradoxical Image Scoring\", \"paradoxical Shunning\", \"U2\", \"U4\", \"U5\", \"U6\", \"U7\", \"U10\", \"U14\"]\n",
    "full_range = [\"#1f77b4\", \"#2ca02c\", \"#ff7f0e\", \"#d62728\", \"#9467bd\", \"#8c564b\", \"#e377c2\", \"#17becf\", \"#bcbd22\", \"#7f7f7f\", \"#c7c7c7\", \"#aec7e8\", \"#ffbb78\", \"#98df8a\", \"#c5b0d5\", \"#dbdb8d\"]\n",
    "# 4. Charting logic\n",
    "# Use the Nominal (:N) shorthand to ensure Altair recognizes the field type explicitly\n",
    "base = alt.Chart(df_combined).encode(\n",
    "    x=alt.X('EBSN:N', sort=None, title=None, axis=alt.Axis(labelAngle=-45)),\n",
    "    y=alt.Y('ACR:Q', scale=alt.Scale(domain=[0, 1]), title='Avg Cooperation (ACR)')\n",
    ")\n",
    "\n",
    "error_bars = base.mark_errorbar(ticks=True, color='black').encode(\n",
    "    yError='Standard Deviation:Q'\n",
    ")\n",
    "\n",
    "points = base.mark_point(filled=True, size=85).encode(\n",
    "    # Explicitly add :N here\n",
    "    color=alt.Color('Cooperative-Social Norm:N',  \n",
    "                    scale=alt.Scale(domain=full_domain, range=full_range),\n",
    "                    legend=alt.Legend(title=\"Cooperative Rule\", orient='bottom', columns=3)),\n",
    "    stroke=alt.condition(alt.datum.is_baseline == 1, alt.value('black'), alt.value(None)),\n",
    "    strokeWidth=alt.condition(alt.datum.is_baseline == 1, alt.value(2), alt.value(0)),\n",
    "    tooltip=['EBSN:N', 'Base Norm:N', 'Cooperative-Social Norm:N', 'ACR:Q', 'Standard Deviation:Q']\n",
    ")\n",
    "\n",
    "# Apply facet and resolve\n",
    "faceted_chart = (error_bars + points).facet(\n",
    "    column=alt.Column('Base Norm:N', title=\"Evolutionary Performance: Top 10 vs. Baseline\"),\n",
    "    spacing=15\n",
    ").resolve_scale(\n",
    "    x='independent'\n",
    ").properties(\n",
    "    title='Comparative Performance of EBSNs (Baselines placed on the far right)'\n",
    ").configure_view(\n",
    "    stroke=None\n",
    ")\n",
    "\n",
    "faceted_chart.display()"
   ]
  },
