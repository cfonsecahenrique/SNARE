": null, \"G\": null, \"DBM\": null, \"DGM\": null, \"CBM\": null, \"CGM\": null, \"DBO\": null, \"DGO\": null, \"CBO\": null, \"CGO\": null, \"DB\": null, \"DG\": null, \"CB\": null, \"CG\": null, \"is_baseline\": 1}, {\"EBSN\": \"11000011\", \"Base Norm\": \"Stern Judging\", \"Cooperative-Social Norm\": \"Stern Judging\", \"Competitive-Social Norm\": null, \"ACR\": 0.061317, \"Standard Deviation\": 0.00295973700823143, \"DNF Literals\": null, \"Freq_AC\": null, \"Freq_Disc\": null, \"Freq_Paradox\": null, \"Freq_AD\": null, \"Freq_Coop_EP\": null, \"Freq_Comp_EP\": null, \"G\": null, \"DBM\": null, \"DGM\": null, \"CBM\": null, \"CGM\": null, \"DBO\": null, \"DGO\": null, \"CBO\": null, \"CGO\": null, \"DB\": null, \"DG\": null, \"CB\": null, \"CG\": null, \"is_baseline\": 1}, {\"EBSN\": \"11000011\", \"Base Norm\": \"Stern Judging\", \"Cooperative-Social Norm\": \"Stern Judging\", \"Competitive-Social Norm\": null, \"ACR\": 0.061317, \"Standard Deviation\": 0.00295973700823143, \"DNF Literals\": null, \"Freq_AC\": null, \"Freq_Disc\": null, \"Freq_Paradox\": null, \"Freq_AD\": null, \"Freq_Coop_EP\": null, \"Freq_Comp_EP\": null, \"G\": null, \"DBM\": null, \"DGM\": null, \"CBM\": null, \"CGM\": null, \"DBO\": null, \"DGO\": null, \"CBO\": null, \"CGO\": null, \"DB\": null, \"DG\": null, \"CB\": null, \"CG\": null, \"is_baseline\": 1}]}}, {\"mode\": \"vega-lite\"});\n",
