   "source": [
    "# 1. Define the mapping for known names\n",
    "norm_mapping = {\n",
    "    (0, 0, 1, 1): \"Image Scoring\",\n",
    "    (1, 0, 0, 1): \"Stern Judging\",\n",
    "    (0, 0, 0, 1): \"Shunning\",\n",
    "    (1, 0, 1, 1): \"Simple Standing\",\n",
    "    (0, 0, 0, 0): \"All Bad\",\n",
    "    (1, 1, 1, 1): \"All Good\",\n",
    "}\n",
    "\n",
    "def identify_detailed_norm(bits):\n",
    "    \"\"\"Returns the name if known, otherwise returns the vector as a string.\"\"\"\n",
    "    vec = tuple(bits)\n",
    "    return norm_mapping.get(vec, str(vec))\n",
    "\n",
    "# 2. Extract detailed frequencies from your top_10_final dataframe\n",
    "# We re-calculate based on the bit columns already in your dataframe\n",
    "top_10_final['Coop_Rule_Full'] = top_10_final[['DBO', 'DGO', 'CBO', 'CGO']].apply(identify_detailed_norm, axis=1)\n",
    "top_10_final['Comp_Rule_Full'] = top_10_final[['DBM', 'DGM', 'CBM', 'CGM']].apply(identify_detailed_norm, axis=1)\n",
    "\n",
    "# 3. Frequency Analysis\n",
    "# How many times does each specific 4-bit rule appear in each context?\n",
    "coop_counts = top_10_final['Coop_Rule_Full'].value_counts().reset_index(name='Coop_Context_Freq')\n",
    "comp_counts = top_10_final['Comp_Rule_Full'].value_counts().reset_index(name='Comp_Context_Freq')\n",
    "\n",
    "# 4. Hybrid Pair Analysis (Exact Rule Combinations)\n",
    "hybrid_analysis = top_10_final.groupby(['Comp_Rule_Full', 'Coop_Rule_Full']).size().reset_index(name='Frequency')\n",
    "hybrid_analysis = hybrid_analysis.sort_values('Frequency', ascending=False).reset_index(drop=True)\n",
    "\n",
    "print(\"--- Frequency of Rules in Cooperative Context ---\")\n",
    "display(coop_counts)\n",
    "\n",
    "print(\"\\n--- Frequency of Rules in Competitive Context ---\")\n",
    "display(comp_counts)\n",
    "\n",
    "print(\"\\n--- Top Hybrid Rule Combinations ---\")\n",
    "display(hybrid_analysis.head(20))"
   ]
  },
