    }
   ],
   "source": [
    "# 1. Filter for Leading Four to keep the analysis focused\n",
    "top_tier = top_10_final[top_10_final[\"Base Norm\"].isin(leading_four)]\n",
    "\n",
    "# 2. Find the most frequent 8-bit vectors\n",
    "champion_counts = top_tier['EBSN'].value_counts().reset_index()\n",
    "champion_counts.columns = ['EBSN', 'Appearance_Count']\n",
    "\n",
    "# 3. Pull details for the top vectors\n",
    "top_vectors = champion_counts[champion_counts['Appearance_Count'] >= 2]\n",
    "top_details = top_tier[top_tier['EBSN'].isin(top_vectors['EBSN'])].drop_duplicates('EBSN')\n",
    "\n",
    "print(\"--- Top Occurring EBSN Vectors Across Leading Four ---\")\n",
    "bests = top_details[['EBSN', 'Cooperative-Social Norm', 'Competitive-Social Norm']].merge(champion_counts)\n",
    "display(bests[bests.Appearance_Count==4])"
   ]
  },
