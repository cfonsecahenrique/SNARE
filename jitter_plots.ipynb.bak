   "source": [
    "def get_all_ebsns_extended(df, gamma=1, z=40, gens=400, chi=0.01, eps=0.01, q=1):\n",
    "    # 1. Apply strict parameter filters\n",
    "    mask = (\n",
    "        (df['gamma_center'] == gamma) &\n",
    "        (df['Z'] >= z) &\n",
    "        (df['gens'] >= gens) &\n",
    "        (df['chi'] == chi) &\n",
    "        (df['eps'] == eps) &\n",
    "        (df['q'] == q) &\n",
    "        (df['Emotion_Leniency'] != 1) &\n",
    "        (df['8bit_vector'].isin(unique_norms_str))\n",
    "    )\n",
    "    filtered_df = df[mask].copy()\n",
    "\n",
    "    # Safety Check: If no data exists for this q, return empty DF instead of crashing\n",
    "    if filtered_df.empty:\n",
    "        print(f\"--- WARNING: No data found for q={q} and gamma={gamma} ---\")\n",
    "        return pd.DataFrame()\n",
    "\n",
    "    if filtered_df['average_cooperation'].max() > 1.1:\n",
    "        filtered_df['average_cooperation'] = filtered_df['average_cooperation'] / 100.0\n",
    "\n",
    "    # 2. Aggregation logic\n",
    "    def calculate_stats(group):\n",
    "        # The iloc[0] check is safer here\n",
    "        stats = {}\n",
    "        coop = group['average_cooperation']\n",
    "        \n",
    "        stats['ACR'] = coop.mean()\n",
    "        stats['Standard Deviation'] = coop.std()\n",
    "        \n",
    "        # Capture metadata safely\n",
    "        stats['4bit_orig'] = group['4bit_orig'].iloc[0] if not group['4bit_orig'].empty else \"\"\n",
    "        stats['DNF Literals'] = group['DNF_literals'].iloc[0] if 'DNF_literals' in group.columns else np.nan\n",
    "        \n",
    "        # Strategy Average Frequencies\n",
    "        stats['Freq_AC'] = group['ALWAYS_COOPERATE'].mean()\n",
    "        stats['Freq_Disc'] = group['DISCRIMINATE'].mean()\n",
    "        stats['Freq_Paradox'] = group['PARADOXICALLY_DISC'].mean()\n",
    "        stats['Freq_AD'] = group['ALWAYS_DEFECT'].mean()\n",
    "        \n",
    "        # Emotion Profile Average Frequencies\n",
    "        stats['Freq_Coop_EP'] = group['EmotionProfile.COOPERATIVE'].mean()\n",
    "        stats['Freq_Comp_EP'] = group['EmotionProfile.COMPETITIVE'].mean()\n",
    "        \n",
    "        stats['G'] = group['G'].mean()\n",
    "        \n",
    "        return pd.Series(stats)\n",
    "\n",
    "    # 3. Grouping - Removing the .head(10) to keep ALL results\n",
    "    grouped = filtered_df.groupby(['base_social_norm', '8bit_vector']).apply(calculate_stats).reset_index()\n",
    "    \n",
    "    # Sort by Base Norm and ACR descending\n",
    "    all_ebsns = grouped.sort_values(['base_social_norm', 'ACR'], ascending=[True, False])\n",
    "\n",
    "    # 4. Final Formatting & Bit Extraction\n",
    "    all_ebsns = all_ebsns.rename(columns={'8bit_vector': 'EBSN', 'base_social_norm': 'Base Norm'})\n",
    "\n",
    "    # Extract Bits using string indexing\n",
    "    all_ebsns['DBM'] = all_ebsns['EBSN'].str[0].astype(int)\n",
    "    all_ebsns['DGM'] = all_ebsns['EBSN'].str[2].astype(int)\n",
    "    all_ebsns['CBM'] = all_ebsns['EBSN'].str[4].astype(int)\n",
    "    all_ebsns['CGM'] = all_ebsns['EBSN'].str[6].astype(int)\n",
    "    all_ebsns['DBO'] = all_ebsns['EBSN'].str[1].astype(int)\n",
    "    all_ebsns['DGO'] = all_ebsns['EBSN'].str[3].astype(int)\n",
    "    all_ebsns['CBO'] = all_ebsns['EBSN'].str[5].astype(int)\n",
    "    all_ebsns['CGO'] = all_ebsns['EBSN'].str[7].astype(int)\n",
    "    \n",
    "    all_ebsns['DB'] = all_ebsns['4bit_orig'].str[0]\n",
    "    all_ebsns['DG'] = all_ebsns['4bit_orig'].str[1]\n",
    "    all_ebsns['CB'] = all_ebsns['4bit_orig'].str[2]\n",
    "    all_ebsns['CG'] = all_ebsns['4bit_orig'].str[3]\n",
    "\n",
    "    def identify_coop_norm(row):\n",
    "        vector = (row['DBO'], row['DGO'], row['CBO'], row['CGO'])\n",
    "        return norm_mapping.get(vector, \"Unknown\")\n",
    "\n",
    "    def identify_comp_norm(row):\n",
    "        vector = (row['DBM'], row['DGM'], row['CBM'], row['CGM'])\n",
    "        return norm_mapping.get(vector, \"Unknown\")\n",
    "\n",
    "    all_ebsns['Cooperative-Social Norm'] = all_ebsns.apply(identify_coop_norm, axis=1)\n",
    "    all_ebsns['Competitive-Social Norm'] = all_ebsns.apply(identify_comp_norm, axis=1)\n",
    "\n",
    "    # Define Column Order\n",
    "    bit_columns = ['DBM', 'DGM', 'CBM', 'CGM', 'DBO', 'DGO', 'CBO', 'CGO', 'DB', 'DG', 'CB', 'CG']\n",
    "    column_order = [\n",
    "        'EBSN', 'Base Norm', 'Cooperative-Social Norm', 'Competitive-Social Norm',\n",
    "        'ACR', 'Standard Deviation', 'DNF Literals',\n",
    "        'Freq_AC', 'Freq_Disc', 'Freq_Paradox', 'Freq_AD',\n",
    "        'Freq_Coop_EP', 'Freq_Comp_EP', 'G'\n",
    "    ] + bit_columns\n",
    "    \n",
    "    return all_ebsns[column_order].reset_index(drop=True)\n",
    "\n",
    "# --- Execution and Slicing ---\n",
    "all_results_q75 = get_all_ebsns_extended(merged_df, q=0.75)\n",
    "\n",
    "display(all_results_q75)"
   ]
  },
