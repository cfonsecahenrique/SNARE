   "source": [
    "# --- 1. Filter and Aggregate ---\n",
    "\n",
    "unique_norms_str = [\"\".join(map(str, norm)) for norm in unique_norms]\n",
    "\n",
    "target_gammas = [0, 0.5, 1]\n",
    "filtered_df = merged_df[merged_df['gamma_center'].isin(target_gammas)].copy()\n",
    "filtered_df = filtered_df[(filtered_df.Z>=40) & (filtered_df.q==1) & (filtered_df.gens>=400)]\n",
    "filtered_df = filtered_df[(filtered_df.chi==0.01) & (filtered_df.eps==0.01)]\n",
    "\n",
    "# Apply the logic to create both columns\n",
    "\n",
    "norms_split = filtered_df.apply(get_emotional_norms, axis=1)\n",
    "filtered_df['Cooperative-Social Norm'] = [x[0] for x in norms_split]\n",
    "filtered_df['Competitive-Social Norm'] = [x[1] for x in norms_split]\n",
    "\n",
    "filtered_df = filtered_df[\n",
    "    (filtered_df['Emotion_Leniency'] != 1) | (filtered_df['gamma_center'] == 0)\n",
    "]\n",
    "\n",
    "\n",
    "filtered_df['average_cooperation'] = filtered_df['average_cooperation'] / 100.0\n",
    "\n",
    "mask = (filtered_df[\"8bit_vector\"].isin(unique_norms_str)) | (filtered_df['gamma_center'] == 0)\n",
    "\n",
    "filtered_df = filtered_df[mask]\n",
    "\n",
    "target_base_norm = \"Shunning\" \n",
    "color_column = 'Cooperative-Social Norm' # CHOOSE: 'Cooperative-Social Norm' or 'Competitive-Social Norm'\n",
    "plot_data = filtered_df[filtered_df['base_social_norm'] == target_base_norm].copy()\n",
    "\n",
    "agg_df = plot_data.groupby([\n",
    "    'eb_social_norm', 'gamma_center', 'DNF_literals',\n",
    "    'Cooperative-Social Norm', 'Competitive-Social Norm'\n",
    "]).agg({\n",
    "    'average_cooperation': 'mean'\n",
    "}).reset_index() \n",
    "\n",
    "domain = [\n",
    "    \"Stern Judging\", \"Simple Standing\", \"Shunning\", \"Image Scoring\", \n",
    "    \"All Good\", \"All Bad\", \"Other\"\n",
    "]\n",
    "range_ = [\n",
    "    \"#1f77b4\", \"#ff7f0e\", \"#2ca02c\", \"#bcbd22\", \n",
    "    \"#9467bd\", \"#d62728\", \"#7f7f7f\"\n",
    "]\n",
    "\n",
    "jitter_chart = alt.Chart(agg_df).mark_circle(size=70, opacity=0.8).encode(\n",
    "    x=alt.X('gamma_center:O', title='Gamma Center'),\n",
    "    y=alt.Y('average_cooperation:Q', title='Average Cooperation', scale=alt.Scale(domain=[0, 1])),\n",
    "    xOffset=alt.XOffset('jitter:Q', scale=alt.Scale(domain=[-2, 2])),   \n",
    "    color=alt.Color(f'{color_column}:N',\n",
    "        scale=alt.Scale(domain=domain, range=range_),\n",
    "        legend=alt.Legend(title=color_column.replace('-', ' '))\n",
    "    ),\n",
    "    tooltip=[\n",
    "        alt.Tooltip('eb_social_norm', title='EB Norm'),\n",
    "        alt.Tooltip('Cooperative-Social Norm', title='Coop Rule'),\n",
    "        alt.Tooltip('Competitive-Social Norm', title='Comp Rule'),\n",
    "        alt.Tooltip('average_cooperation', title='Avg Coop', format='.3f'),\n",
    "        alt.Tooltip('DNF_literals', title='Complexity')\n",
    "    ]\n",
    ").transform_calculate(\n",
    "    jitter='datum.gamma_center == 0 ? 0 : (random()-0.5)'\n",
    ").properties(\n",
    "    title=f\"EB-Extension: {target_base_norm} (Color: {color_column})\",\n",
    "    width=450,\n",
    "    height=500\n",
    ").interactive()\n",
    "\n",
    "jitter_chart.display()"
   ]
  },
